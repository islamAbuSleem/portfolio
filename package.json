{
  "name": "senior-portfolio",
  "version": "1.0.0",
  "description": "A sophisticated portfolio for a senior software engineer",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "db:generate": "cd server/api/express && drizzle-kit generate",
    "db:migrate": "cd server/api/express && tsx src/db/migrate.ts",
    "db:push": "cd server/api/express && drizzle-kit push",
    "db:studio": "cd server/api/express && drizzle-kit studio",
    "db:seed": "cd server/api/express && tsx src/db/seed.ts"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.16",
    "@neondatabase/serverless": "^1.0.2",
    "@nuxtjs/color-mode": "^3.3.2",
    "@nuxtjs/tailwindcss": "^6.10.4",
    "@pinia/nuxt": "^0.11.3",
    "@sentry/node": "^10.38.0",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.5",
    "framer-motion": "^10.16.16",
    "gsap": "^3.12.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-vue-next": "^0.294.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nuxt": "^3.9.1",
    "pinia": "^3.0.4",
    "postgres": "^3.4.8",
    "vue": "^3.4.0",
    "vue-advanced-cropper": "^2.8.9",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nuxt/devtools": "^1.0.8",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.1",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.16",
    "drizzle-kit": "^0.31.8",
    "jsdom": "^28.0.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
